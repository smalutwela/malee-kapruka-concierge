# ============================================================
#  AI provider — pick ONE. Default is Google Gemini (free tier).
# ============================================================

# --- Option A: Google Gemini (free, default) ---
# Get a free key at https://aistudio.google.com/apikey  (no billing setup needed)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# --- Option B: Claude (switch later for max quality) ---
# Set the provider to anthropic and add a key from https://console.anthropic.com
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---
# Pin a specific model (otherwise: gemini-3.1-flash-lite for google, claude-sonnet-4-6 for anthropic).
#   For top Claude quality: AGENT_MODEL=claude-opus-4-8
# AGENT_MODEL=gemini-3.1-flash-lite

# Kapruka MCP endpoint. Default: https://mcp.kapruka.com/mcp
# KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# Global circuit breaker: max chat requests per UTC day (protects a paid API
# balance from traffic spikes). Default 600 — just above Gemini's free-tier
# 500/day, so on the free model the provider quota still bites first.
# DAILY_CHAT_CAP=600
