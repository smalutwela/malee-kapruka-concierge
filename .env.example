# ============================================================
#  AI models — Claude primary, free-Gemini fallback (default)
# ============================================================
# With BOTH keys set, the agent runs on Claude and automatically falls back to
# Gemini's free tier on ANY Claude error (credits exhausted, rate limit, model
# unavailable, network). Set only the Gemini key to run Gemini-only (no Claude
# spend).

# --- Gemini (free) — the fallback, and standalone if no Claude key is set ---
# Free key, no billing setup: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# --- Claude (primary) — add a key + prepaid credits to enable it ---
# Key: https://console.anthropic.com
# The spend cap is enforced by Anthropic, not the app: buy prepaid credits with
# auto-reload OFF (+ an optional workspace spend limit). The minimum credit
# purchase is $5; to test against ~$1 first, set a $1 workspace spend limit.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---
# Force a single provider (overrides the Claude+fallback default):
#   AI_PROVIDER=anthropic  → Claude only, no fallback (isolate Claude)
#   AI_PROVIDER=google     → Gemini only, no Claude spend (kill switch)
# AI_PROVIDER=

# Pin the primary model id (default claude-sonnet-4-6; or the Gemini model when
# AI_PROVIDER=google). For top Claude quality: AGENT_MODEL=claude-opus-4-8
# AGENT_MODEL=claude-sonnet-4-6

# Kapruka MCP endpoint. Default: https://mcp.kapruka.com/mcp
# KAPRUKA_MCP_URL=https://mcp.kapruka.com/mcp

# Global circuit breaker: max chat requests per UTC day (protects your paid
# Claude credits from a traffic spike). Default 600.
# DAILY_CHAT_CAP=600
